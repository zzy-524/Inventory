{
  "name": "inventory-app",
  "version": "1.0.0",
  "description": "Inventory Management System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server.cjs",
    "start": "node server.cjs",
    "desktop": "open src-tauri/target/release/bundle/macos/InventoryApp.app",
    "deploy": "bash scripts/deploy.sh",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "build:mac": "tauri build --target aarch64-apple-darwin",
    "build:win": "tauri build --target x86_64-pc-windows-gnu --bundles nsis",
    "build:all": "npm run build:mac && npm run build:win"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "antd": "^6.4.3",
    "axios": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.3.0",
    "vite": "^8.0.16"
  }
}
