{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InventoryApp",
  "version": "1.0.0",
  "identifier": "com.inventory.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "库存管理系统",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:8888; img-src 'self' data:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": null,
      "wix": null,
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "resources": [
      "../dist/index.html",
      "../dist/assets/*"
    ]
  }
}